<Window x:Class="TestOpenLockGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestOpenLockGame"
        mc:Ignorable="d"
        Height="550"
        Width="600" 
        WindowStartupLocation="CenterScreen"     
        ResizeMode="NoResize"
        KeyDown="Control">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>        
        
        <Border x:Name="Gutter" Grid.Column="0" Grid.Row="0" Padding="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10">
            <Border x:Name="Speedway">
                <Border x:Name="Runner0" VerticalAlignment="Bottom" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="AliceBlue" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Border>
        
        <Border Grid.Column="1" Grid.Row="0" Padding="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10">
            <Border>
                <Border x:Name="Runner1" VerticalAlignment="Bottom" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="AliceBlue" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Border>
        <Border Grid.Column="2" Grid.Row="0" Padding="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10">
            <Border>
                <Border x:Name="Runner2" VerticalAlignment="Bottom" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="AliceBlue" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Border>
        <Border Grid.Column="3" Grid.Row="0" Padding="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10">
            <Border>
                <Border x:Name="Runner3" VerticalAlignment="Bottom" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="AliceBlue" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Border>
        <Border Grid.Column="4" Grid.Row="0" Padding="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10">
            <Border>
                <Border x:Name="Runner4" VerticalAlignment="Bottom" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="AliceBlue" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Border>

        <Grid Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="70*"/>
                <RowDefinition Height="30*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" VerticalAlignment="Bottom" BorderBrush="Red" BorderThickness="0,5,0,0"/>
            <Border Grid.Row="1" BorderBrush="Red" BorderThickness="0,5,0,0"/>
        </Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="5" CornerRadius="10"/>
            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="5" CornerRadius="10"/>
            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="5" CornerRadius="10"/>
            <Border Grid.Column="3" BorderBrush="Black" BorderThickness="5" CornerRadius="10"/>
            <Border Grid.Column="4" BorderBrush="Black" BorderThickness="5" CornerRadius="10"/>

            <Border x:Name="Selector" Margin="6" BorderBrush="Black" BorderThickness="5" CornerRadius="10" Background="Gold" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"/>
        </Grid>
    </Grid>
</Window>
